# @ngrx/signals v21 declares a peer dependency on @angular/core ^21 but is
# compatible with Angular 22. NgRx aligns each major with the matching Angular
# major, and v22 is not released yet. See https://github.com/ngrx/platform/issues/5158
# Remove this once @ngrx/signals v22 is published.
legacy-peer-deps=true
